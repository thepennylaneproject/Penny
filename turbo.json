{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true
    },
    "build": {
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "tsconfig.json",
        "next.config.ts",
        "vite.config.ts"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
