{
  "name": "penny-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib hooks --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "migrate": "tsx scripts/migrate.ts",
    "setup": "npm run migrate && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@sentry/nextjs": "^10.44.0",
    "bullmq": "^5.71.0",
    "next": "^16.1.7",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
