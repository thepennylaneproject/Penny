    {
      "finding_id": "f-ed623fc2",
      "category": "index",
      "title": "Should findings have a composite index on (project_id, status, created_at)?",
      "type": "question",
      "severity": "minor",
      "priority": "P2",
      "confidence": "inference",
      "estimated_effort": "small",
      "status": "accepted",
      "description": "Migrations define idx_findings_project and idx_findings_status separately. Dashboard queries often filter by project_id and optionally status with ordering by created_at. A composite index may reduce heap fetches versus BitmapAnd of two indexes, but this should be validated with real row counts and plans.",
      "proof_hooks": [
        {
          "hook_type": "code_ref",
          "summary": "Separate indexes",
          "file": "supabase/migrations/20260402163739_lyra_schema.sql",
          "value": "CREATE INDEX idx_findings_project ON findings(project_id); CREATE INDEX idx_findings_status ON findings(status);",
          "start_line": 117
        },
        {
          "hook_type": "query",
          "summary": "Suggested validation",
          "value": "EXPLAIN (ANALYZE, BUFFERS) SELECT id, title FROM findings WHERE project_id = $1 AND status = $2 ORDER BY created_at DESC LIMIT 50;"
        }
      ],
      "suggested_fix": {
        "approach": "Run EXPLAIN ANALYZE on production-like data; add CREATE INDEX CONCURRENTLY on (project_id, status, created_at DESC) if seq scans or high buffer reads appear.",
        "steps": [
          "Capture baseline plan from Supabase SQL editor.",
          "Compare before/after index addition in a staging branch."
        ]
      },
      "history": [
        {
          "timestamp": "2026-04-07T18:45:00.000Z",
          "actor": "synthesizer",
          "event": "note_added",
          "notes": "Normalized finding_id from perf agent id field; merged history."
        },
        {
          "timestamp": "2026-04-07T17:49:40Z",
          "actor": "solo-dev",
          "event": "note_added",
          "notes": "Decision: Add index"
        }
      ],
      "sources": [
        "perf-20260407-121845"
      ]
