# Penny v3.0 Environment Variables
# Copy this to .env.local and fill in your actual values

# ─── Dashboard (Netlify) ────────────────────────────────────────────

# Auth
DASHBOARD_API_SECRET=your-secret-unlock-screen-password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Edge Function `ingest-audit`: set in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# as AUDIT_INGEST_SECRET. Callers send Authorization: Bearer <secret> or x-penny-api-secret.
# AUDIT_INGEST_SECRET=generate-a-long-random-string
# Required for /api/* when using Supabase sign-in: middleware verifies the access token (see apps/dashboard/proxy.ts).
# Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret
# Optional; default is "authenticated"
# SUPABASE_JWT_AUDIENCE=authenticated
# Lane
NEXT_PUBLIC_LANE_API_BASE_URL=https://your-lane-api.example.com
# PostgreSQL connection for dashboard project CRUD (penny_projects table).
# Use the Supabase "Transaction pooler" connection string from:
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Repair service
REPAIR_SERVICE_URL=https://YOUR_REPAIR_SERVICE.up.railway.app
REPAIR_SERVICE_SECRET=your-bearer-token

# Upstash Redis (for manual API calls)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Observability (same DSN for server + browser in Next.js unless you split projects)
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# GitHub App (for webhook registration + PR creation)
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY=your-private-key-pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Linear (optional)
LINEAR_API_KEY=your-api-key
LINEAR_TEAM_ID=your-team-id

# ─── Worker (Railway) ──────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (BullMQ transport)
REDIS_URL=rediss://xxx.upstash.io:6380
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# LLM providers
ANTHROPIC_API_KEY=your-key
OPENAI_API_KEY=your-key
GEMINI_API_KEY=your-key
AIMLAPI_API_KEY=your-key
HF_TOKEN=your-token

# Routing strategy
PENNY_ROUTING_STRATEGY=balanced

# Repair service
REPAIR_SERVICE_URL=https://YOUR_REPAIR_SERVICE.up.railway.app
REPAIR_SERVICE_SECRET=your-bearer-token

# GitHub App
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY=your-private-key-pem

# Observability
PENNY_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Worker tuning (optional)
penny_JOB_POLL_MS=3000
penny_JOB_POLL_IDLE_MS=5000
penny_JOB_POLL_BATCH_SIZE=10
# Parallel work inside one job (see apps/worker/src/concurrency-config.ts)
# penny_PASS_CONCURRENCY=2
# penny_PORTFOLIO_PROJECT_CONCURRENCY=1
# Override Postgres pool max; default scales with pass + portfolio concurrency (+ slack)
# penny_PG_POOL_MAX=12

# ─── Repair Service (Railway) ──────────────────────────────────────

# Auth
REPAIR_SERVICE_SECRET=your-bearer-token

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM providers (full multi-provider gateway)
ANTHROPIC_API_KEY=your-key
OPENAI_API_KEY=your-key
GEMINI_API_KEY=your-key
AIMLAPI_API_KEY=your-key
HF_TOKEN=your-token

# Vector memory (Qdrant Cloud)
penny_QDRANT_URL=https://xxx.qdrant.io
penny_QDRANT_COLLECTION=penny_patch_memory
QDRANT_API_KEY=your-key

# Repair engine tuning
penny_ROOT_BRANCHING_FACTOR=5
penny_BEAM_WIDTH=2
penny_MAX_DEPTH=2
penny_MAX_EVALS_PER_FINDING=20
penny_AUTO_APPLY=true
penny_EVAL_USE_DOCKER=true
penny_DOCKER_IMAGE=python:3.11
penny_EVAL_TIMEOUT_SECONDS=300
penny_STRONG_PASS_SCORE=0.93

# Model overrides (optional)
penny_ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
penny_ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest
penny_ANTHROPIC_OPUS_MODEL=claude-3-opus-latest

# Observability
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# ─── Supabase Edge Functions ───────────────────────────────────────
# Set these via `supabase secrets set` command

# SUPABASE_URL=<auto-injected>
# SUPABASE_SERVICE_ROLE_KEY=<service_role>
# GITHUB_WEBHOOK_SECRET=<secret>
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<token>
# REPAIR_SERVICE_URL=https://YOUR_REPAIR_SERVICE.up.railway.app
# REPAIR_SERVICE_SECRET=<bearer_token>
