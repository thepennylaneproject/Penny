{
  "name": "penny",
  "version": "3.0.0",
  "description": "Penny v3.0 — Multi-agent code auditing and repair system",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "cd supabase && supabase db push"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
